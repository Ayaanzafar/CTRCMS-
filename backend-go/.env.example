# Copy to backend-go/.env

DATABASE_URL=postgresql://ctrcms:ctrcms_dev_password@127.0.0.1:5435/ctrcms?sslmode=disable
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h
# Reuse existing Node upload files (69+ files in backend/uploads)
UPLOAD_DIR=../backend/uploads
MAX_FILE_SIZE_MB=25
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
