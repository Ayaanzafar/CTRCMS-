{
  "name": "ctrcms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "cd backend && npm install && npm run db:setup",
    "backend:install": "cd backend-go && go mod tidy",
    "backend:dev": "cd backend-go && make run",
    "backend:test": "cd backend-go && make test",
    "backend:legacy:dev": "cd backend && npm run dev",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "setup": "npm run db:up && npm run db:setup && npm run backend:install && npm run frontend:install"
  }
}
